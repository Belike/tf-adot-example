    {
      "type": "metric",
      "x": 12,
      "y": 2,
      "width": 12,
      "height": 4,
      "properties": {
        "title": "Cluster change status (CANCELLED/COMPLETED/FAILED/IN_PROGRESS)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            {
              "expression": "SEARCH('{ContainerInsights/Prometheus,Namespace,Service} MetricName=\"zeebe_cluster_changes_status\" Namespace=\"camunda\" Service=\"camunda-platform\"', 'Average', 60)",
              "id": "e1"
            }
          ]
        ],
        "region": "eu-west-1",
        "yAxis": {
          "left": {
            "min": 0
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 8,
      "height": 6,
