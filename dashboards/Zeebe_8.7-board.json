              "expression": "RATE(SEARCH('{ContainerInsights/Prometheus,Namespace,Service,partition} MetricName=\"zeebe_stream_processor_records_total\" Namespace=\"camunda\" Service=\"camunda-platform\"', 'Sum', 60))*60",
