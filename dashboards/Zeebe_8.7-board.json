{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Camunda 8.7 \u2014 Cluster Dashboard\n*Namespace=`camunda`, Service=`camunda-platform`. Per-partition widgets use schema `{Namespace,Service,partition}`. Per-component (JVM/CPU) widgets use `{Namespace,Component}`. Schemas must match the dimension sets the ADOT collector emits \u2014 extra dims yield zero results.*"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 1,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## General Overview"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 2,
      "width": 4,
      "height": 4,
      "properties": {
        "title": "Partition health (min)",
        "view": "singleValue",
        "stacked": false,
        "metrics": [
          [
            "ContainerInsights/Prometheus",
            "zeebe_health",
            "Namespace",
            "camunda",
            "Service",
            "camunda-platform",
            {
              "stat": "Minimum",
              "period": 60,
              "label": "Min health"
            }
          ]
        ],
        "region": "eu-west-1"
      }
    },
    {
      "type": "metric",
      "x": 4,
      "y": 2,
      "width": 4,
      "height": 4,
      "properties": {
        "title": "Banned instances",
        "view": "singleValue",
        "stacked": false,
        "metrics": [
          [
            "ContainerInsights/Prometheus",
            "zeebe_banned_instances_total",
            "Namespace",
            "camunda",
            "Service",
            "camunda-platform",
            {
              "stat": "Maximum",
              "period": 60,
              "label": "Banned"
            }
          ]
        ],
        "region": "eu-west-1"
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 2,
      "width": 4,
      "height": 4,
